<!DOCTYPE html>
<html lang="pt-br">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Editar Lançamento</title>
    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600;700&display=swap" rel="stylesheet">
    <!-- Bootstrap CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet"
        integrity="sha384-sRIl4kxILFvY47J16cr9ZwB07vP4J8+LH7qKQnuqkuIAvNWLzeN8tE5YBujZqJLB" crossorigin="anonymous">
    <!-- Bootstrap JS -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js"
        integrity="sha384-FKyoEForCGlyvwx9Hj09JcYn3nv7wiPVlz7YYwJrWVcXK/BmnVDxM+D2scQbITxI"
        crossorigin="anonymous"></script>
    <!-- Bootstrap Icons -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons/font/bootstrap-icons.css">
    <!-- CSS -->
    <link rel="stylesheet" href="/css/novo_lancamento.css">
    <!-- Favicon -->
    <link rel="shortcut icon" href="/img/icon-plus.png" type="image/x-icon">

</head>

<body>
    <div class="container">
        <header class="header">
            <h2>Editar Lançamento</h2>
        </header>
        <form id="lancamentoForm" action="/salvar_edicao" method="POST">
            <input type="hidden" name="idLancamento" value="<%=lancamento.id%>">
            <div class="form-group">
                <label for="tipo">Tipo</label>
                <div class="radio-group">
                    <div class="radio-option">
                        <input type="radio" id="entrada" name="tipo" value="Entrada" <%=lancamento.tipo === 'Entrada' ? 'checked' : '' %>>
                        <label for="entrada">Entrada</label>
                    </div>
                    <div class="radio-option">
                        <input type="radio" id="saida" name="tipo" value="Saída" <%=lancamento.tipo === 'Saída' ? 'checked' : '' %>>
                        <label for="saida">Saída</label>
                    </div>
                </div>
            </div>

            <div class="row">
                <div class="col-6">
                    <div class="form-group">
                        <label for="valor">Valor (R$)</label>
                        <input type="number" id="valor" name="valor" step="0.01" placeholder="Ex: 1000,00" required value="<%=lancamento.valor%>">
                    </div>
                </div>

                <div class="col-6">
                    <div class="form-group">
                        <label for="categoria">Categoria</label>
                        <select id="categoria" name="categoria" required>
                            <option value="" disabled selected> Selecionar </option>
                            <option value="Salário" <%= lancamento.categoria === 'Salário' ? 'selected' : '' %>> Salário </option>
                            <option value="Poupança" <%= lancamento.categoria === 'Poupança' ? 'selected' : '' %>> Poupança </option>
                            <option value="Transporte" <%= lancamento.categoria === 'Transporte' ? 'selected' : '' %>> Transporte </option>
                            <option value="Mercado" <%= lancamento.categoria === 'Mercado' ? 'selected' : '' %>> Mercado </option>
                            <option value="Contas Fixas" <%= lancamento.categoria === 'Contas Fixas' ? 'selected' : '' %>> Contas Fixas </option>
                            <option value="Emergência" <%= lancamento.categoria === 'Emergência' ? 'selected' : '' %>> Emergência </option>
                        </select>
                    </div>
                </div>
            </div>

            <div class="row">
                <div class="col-6">
                    <div class="form-group">
                        <label for="data">Data</label>
                        <input type="date" id="data" name="data" required min="1999-01-01" max="2099-01-01" value="<%=lancamento.data%>">
                    </div>
                </div>

                <div class="col-6">
                    <div class="form-group">
                        <label for="formaDePagamento">Forma de Pagamento</label>
                        <select id="formaDePagamento" name="formaDePagamento" required>
                            <option value="" disabled>Selecionar</option>
                            <option value="contaCorrente" <%= lancamento.formaDePagamento === 'contaCorrente' ? 'selected' : '' %>>Conta Corrente</option>
                            <option value="credito" <%= lancamento.formaDePagamento === 'credito' ? 'selected' : '' %>>Cartão de Crédito</option>
                            <option value="dinheiro" <%= lancamento.formaDePagamento === 'dinheiro' ? 'selected' : '' %>>Dinheiro Físico</option>
                        </select>
                    </div>
                </div>
            </div>

            <div class="form-group">
                <label for="descricao">Descrição</label>
                <input type="text" id="descricao" name="descricao" placeholder="Ex: Pagamento da conta de energia" required value="<%=lancamento.descricao%>">
            </div>

            <div class="form-group">
                <label for="pessoa">Pessoa:</label>
                <select id="pessoa" name="pessoa" required>
                    <option value="" disabled selected>Selecionar</option>
                    <option value="Raquel">Raquel</option>
                    <option value="Yan">Yan</option>
                </select>
            </div>

            <div class="form-actions">
                <button type="submit" class="btn-save w-50 border-0">
                    <i class="bi bi-check-lg fs-6 text-white"></i> Atualizar
                </button>
                <a href="/extrato" class="btn btn-secondary btn-extrato w-50">
                    <i class="bi bi-x-lg fs-6 text-white"></i> Cancelar
                </a>
            </div>
        </form>
    </div>

    <div class="toast-container position-fixed bottom-0 end-0 p-3">
        <div id="liveToast" class="toast align-items-center text-white bg-success border-0" role="alert"
            aria-live="assertive" aria-atomic="true">
            <div class="d-flex">
                <div class="toast-body d-flex align-items-center">
                    <i class="bi bi-check-circle-fill me-2"></i>
                    Lançamento registrado com sucesso!
                </div>
                <button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast"
                    aria-label="Close"></button>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        const root = document.documentElement;
        const entradaRadio = document.getElementById('entrada');
        const saidaRadio = document.getElementById('saida');
        const btnSalvar = document.querySelector('.btn-save');
        const form = document.getElementById('lancamentoForm');
        const toastLiveExample = document.getElementById('liveToast');
        const toastBootstrap = bootstrap.Toast.getOrCreateInstance(toastLiveExample);

        function updateColors() {
            if (saidaRadio.checked) {
                root.style.setProperty('--primary-green', 'var(--primary-red)');
                btnSalvar.style.backgroundColor = 'var(--primary-red)';
            } else {
                root.style.setProperty('--primary-green', '#4caf50');
                btnSalvar.style.backgroundColor = '#4caf50';
            }
        }

        entradaRadio.addEventListener('change', updateColors);
        saidaRadio.addEventListener('change', updateColors);

        // Intercepta o envio do formulário
        form.addEventListener('submit', function (event) {
            event.preventDefault();
            toastBootstrap.show();
            setTimeout(() => {
                form.submit();
            }, 800);
        });

        updateColors();
    </script>
</body>

</html>